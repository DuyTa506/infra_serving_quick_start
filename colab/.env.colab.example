# Colab single-A100 config. The notebook sets these as environment variables before
# launching. Copy/edit values inside the notebook's Config cell (cell 3) — this file is the
# reference of every knob.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared key. The cloudflared URL is PUBLIC, so unlike the Docker stack the gateway
# REQUIRES the backend to send this as `Authorization: Bearer <API_KEY>`.
API_KEY=sk-secai2026
# HuggingFace token (recommended: faster downloads, needed for any gated repo).
HF_TOKEN=hf_xxx

# ── Models ────────────────────────────────────────────────────────────────────
# LLM: A100 cannot run NVFP4. Closest match = the SAME Qwen3-30B-A3B MoE quantized to
# int4 AWQ (~18 GB). Alternatives: stelterlab/Qwen3-30B-A3B-Instruct-2507-AWQ,
# cyankiwi/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit.
LLM_MODEL=cpatonn/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B

# AWQ on Ampere → marlin kernel. Set to gptq_marlin for a GPTQ build, or empty to
# let vLLM auto-detect from the model config.
LLM_QUANTIZATION=awq_marlin
# 2507-Instruct is non-thinking (no <think> blocks) → no reasoning parser. Tool calls
# use the hermes parser. If you switch to a *thinking* Qwen3 build, also set a reasoning
# parser inside launch_vllm.py.
LLM_TOOL_PARSER=hermes

# Context window. AWQ int4 weights are small, so KV cache has lots of room; raise toward
# 262144 if your backend needs the model's full context (watch VRAM).
LLM_MAX_MODEL_LEN=32768

# ── VRAM split on the single 80 GB card (must sum to < 1.0) ───────────────────
# Default 0.60 + 0.05 + 0.06 = 0.71 → ~57/80 GB, ~23 GB headroom. Don't push past ~0.90.
LLM_GPU_UTIL=0.60
EMBED_GPU_UTIL=0.05
RERANK_GPU_UTIL=0.06

# ── Networking ────────────────────────────────────────────────────────────────
# Internal vLLM ports (behind the gateway); the gateway is the only tunnelled port.
LLM_PORT=8001
EMBED_PORT=8000
RERANK_PORT=8002
GATEWAY_PORT=8080
# Require the backend's Bearer token (recommended for the public URL). 0 = inject only.
GATEWAY_REQUIRE_KEY=1

# Per-service health-gate timeout (s) during sequential startup (model download + load).
HEALTH_TIMEOUT=900
