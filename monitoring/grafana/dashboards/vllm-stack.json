{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["vllm", "gpu", "logs"],
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "custom",
        "query": "All,llm-0,llm-1,embedding-0,embedding-1,reranker-0,reranker-1,nginx",
        "current": { "text": "All", "value": ".+" },
        "options": [
          { "text": "All", "value": ".+", "selected": true },
          { "text": "llm-0", "value": "llm-0", "selected": false },
          { "text": "llm-1", "value": "llm-1", "selected": false },
          { "text": "embedding-0", "value": "embedding-0", "selected": false },
          { "text": "embedding-1", "value": "embedding-1", "selected": false },
          { "text": "reranker-0", "value": "reranker-0", "selected": false },
          { "text": "reranker-1", "value": "reranker-1", "selected": false },
          { "text": "nginx", "value": "nginx", "selected": false }
        ],
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "title": "vLLM Serving — GPU & Logs",
  "uid": "vllm-stack",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "GPU (NVIDIA DCGM)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "GPU Utilization %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "GPU {{gpu}} ({{modelName}})", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "VRAM Used (MiB)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "DCGM_FI_DEV_FB_USED", "legendFormat": "GPU {{gpu}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU Temperature (°C)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "DCGM_FI_DEV_GPU_TEMP", "legendFormat": "GPU {{gpu}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU Power Draw (W)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "watt", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "DCGM_FI_DEV_POWER_USAGE", "legendFormat": "GPU {{gpu}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "SM Clock (MHz)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "rotmhz", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        { "expr": "DCGM_FI_DEV_SM_CLOCK", "legendFormat": "GPU {{gpu}}", "refId": "A" }
      ]
    },
    {
      "type": "row",
      "title": "Logs (Loki — all containers)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "title": "Container logs — $container",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 18 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        { "expr": "{job=\"docker\", container=~\"$container\"}", "refId": "A" }
      ]
    }
  ],
  "__inputs": [],
  "__requires": []
}
