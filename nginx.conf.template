# ─── vLLM Serving Stack — Nginx reverse-proxy template ───────────────────────
# Internal ports (vLLM binds to these):
#   embedding :8010  →  external :8000
#   LLM        :8011  →  external :8001
#   reranker   :8012  →  external :8002

    # ── vLLM Embedding  :8000 → :8010 ──────────────────────────────────────────
    server {
        listen 8000;

        location / {
            include snippets/nginx-proxy.conf;
            proxy_set_header Authorization "Bearer ${API_KEY}";
            proxy_pass http://localhost:8010;
            proxy_read_timeout 30s;
            proxy_connect_timeout 5s;
            proxy_send_timeout 10s;
        }
    }

    # ── vLLM LLM  :8001 → :8011 ───────────────────────────────────────────────
    server {
        listen 8001;

        location / {
            include snippets/nginx-proxy.conf;
            proxy_set_header Authorization "Bearer ${API_KEY}";
            proxy_pass http://localhost:8011;
            proxy_read_timeout 600s;
            proxy_connect_timeout 5s;
            proxy_send_timeout 60s;
            proxy_buffering off;
            chunked_transfer_encoding on;
        }
    }

    # ── vLLM Reranker  :8002 → :8012 ──────────────────────────────────────────
    server {
        listen 8002;

        location / {
            include snippets/nginx-proxy.conf;
            proxy_set_header Authorization "Bearer ${API_KEY}";
            proxy_pass http://localhost:8012;
            proxy_read_timeout 30s;
            proxy_connect_timeout 5s;
            proxy_send_timeout 10s;
        }
    }
# ─── /vLLM ───────────────────────────────────────────────────────────────────
