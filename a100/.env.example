# Copy to .env and fill in values:  cp .env.example .env
# (Config cho version 2x A100 80GB. Khác stack root ở phần LLM — xem ghi chú cuối file.)

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared API key cho cả 3 service. nginx inject key này như Bearer token, nên
# client gọi thẳng port public (8000/8001/8002) mà không cần gửi key.
API_KEY=sk-secai2026

# HuggingFace token (cần cho model gated / tải nhanh hơn)
HF_TOKEN=hf_xxx

# ── Models ────────────────────────────────────────────────────────────────────
# LLM: GPTQ INT4 của Qwen3.6-35B-A3B (MoE, ~3.6B active, 35B total).
# palmfuture/Qwen3.6-35B-A3B-GPTQ-Int4 — GPTQ v2, group_size=128, 23 GB.
# Served with --quantization gptq. Có MTP weights cho speculative decoding.
# vLLM auto-detect quant method từ config.json nếu không truyền --quantization.
LLM_MODEL=palmfuture/Qwen3.6-35B-A3B-GPTQ-Int4
# Embedding: bge-m3 (MIT, multilingual, dim 1024). Served pooling, same as root stack.
EMBED_MODEL=BAAI/bge-m3
# Reranker: Qwen3-Reranker-0.6B (causal-LM reranker). Serve-args live in
# &rerank-cmd of docker-compose.yml (--runner pooling + --hf-overrides + jinja template);
# changing this id alone is NOT enough for Qwen3-Reranker models.
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B

# Max context for the LLM. GPTQ INT4 weights (~23 GB) leave plenty of VRAM for KV
# cache on A100 80GB — can raise toward 262144 if you need the full context window.
LLM_MAX_MODEL_LEN=65536

# vLLM image. Pin tag để reproducible (vd: vllm/vllm-openai:v0.x.y).
VLLM_IMAGE=vllm/vllm-openai:latest

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Why A100 differs from the root stack (RTX 6000 Blackwell) ─────────────────
# A100 = Ampere (SM80) — NO NVFP4 (needs SM≥89) and NO FP8 W8A8 (Hopper/Ada).
# This variant uses GPTQ INT4, with FP8/speculative/reasoning removed
# (Ampere can't do native FP8 KV cache; MTP requires NVFP4 build).
# Each A100 runs one full replica (TP=1); nginx LB over 2 cards → ~2× throughput + HA.
