# Copy to .env and fill in values:  cp .env.example .env
# (Config cho version 2x A100 80GB. Khác stack root ở phần LLM — xem ghi chú cuối file.)

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared API key cho cả 3 service. nginx inject key này như Bearer token, nên
# client gọi thẳng port public (8000/8001/8002) mà không cần gửi key.
API_KEY=sk-secai2026

# HuggingFace token (cần cho model gated / tải nhanh hơn)
HF_TOKEN=hf_xxx

# ── Models ────────────────────────────────────────────────────────────────────
# LLM: bản int4 của Qwen3-30B-A3B (MoE, 3B active). Build cpatonn này đóng gói dạng
# `compressed-tensors`; vLLM TỰ NHẬN quantization từ config model (compose KHÔNG ép
# --quantization). Trên A100 (Ampere/SM80) vẫn chạy qua Marlin int4 kernel — fast path.
# Đổi sang bản int4 khác (compressed-tensors/AWQ/GPTQ) chỉ cần đổi id ở đây là đủ.
LLM_MODEL=cpatonn/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit
# Embedding: bge-m3 (MIT, multilingual, dim 1024). Served pooling, giống stack root.
EMBED_MODEL=BAAI/bge-m3
# Reranker: Qwen3-Reranker-0.6B (causal-LM reranker). Serve-args đặc thù nằm trong
# &rerank-cmd của docker-compose.yml (--runner pooling + --hf-overrides + jinja template);
# đổi mỗi id này là KHÔNG đủ cho họ Qwen3-Reranker.
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B

# Context tối đa của LLM. Weights int4 (~18 GB) chừa rất nhiều VRAM cho KV cache trên
# A100 80GB → có thể nâng dần tới 262144 (full context của Qwen3-30B-A3B-2507) nếu cần.
LLM_MAX_MODEL_LEN=32768

# vLLM image. Pin tag để reproducible (vd: vllm/vllm-openai:v0.x.y).
VLLM_IMAGE=vllm/vllm-openai:latest

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Vì sao A100 khác stack root (RTX 6000 Blackwell) ──────────────────────────
# A100 = Ampere (SM80), KHÔNG có NVFP4 (cần SM≥89) và KHÔNG có FP8 W8A8 (Hopper/Ada).
# Nên version này dùng LLM int4 (Marlin kernel, quantization auto-detect từ config), và
# BỎ --kv-cache-dtype fp8 / --speculative-config mtp / --reasoning-parser (xem docker-compose.yml).
# Mỗi A100 chạy 1 replica đầy đủ (TP=1); nginx LB 2 card → ~2x throughput + HA.
