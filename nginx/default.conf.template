# ─── vLLM load balancer ───────────────────────────────────────────────────────
# Rendered by the official nginx image's envsubst at startup: ${API_KEY} comes
# from the container environment. nginx variables ($host, $remote_addr, ...) are
# left untouched (they are not exported env vars).
#
# Auth model: clients hit the public ports WITHOUT a key — nginx injects the
# shared Bearer token and vLLM validates it. Keep these ports behind a firewall
# or front them with your own auth if exposed to the internet.

upstream llm_backend {
    least_conn;                       # long streaming requests → fewest-connections
    server llm-0:8001 max_fails=3 fail_timeout=30s;
    server llm-1:8001 max_fails=3 fail_timeout=30s;
    keepalive 32;
}

upstream embedding_backend {
    server embedding-0:8000 max_fails=3 fail_timeout=30s;
    server embedding-1:8000 max_fails=3 fail_timeout=30s;
    keepalive 16;
}

upstream reranker_backend {
    server reranker-0:8002 max_fails=3 fail_timeout=30s;
    server reranker-1:8002 max_fails=3 fail_timeout=30s;
    keepalive 16;
}

# ── LLM :8001 (OpenAI-compatible, streaming) ─────────────────────────────────
server {
    listen 8001;
    client_max_body_size 64M;

    location / {
        proxy_pass http://llm_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Authorization "Bearer ${API_KEY}";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # streaming: don't buffer SSE chunks
        proxy_buffering off;
        chunked_transfer_encoding on;

        proxy_connect_timeout 5s;
        proxy_send_timeout 60s;
        proxy_read_timeout 600s;

        # if one GPU's replica is down/busy, retry the other
        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 2;
    }
}

# ── Embedding :8000 ──────────────────────────────────────────────────────────
server {
    listen 8000;
    client_max_body_size 64M;

    location / {
        proxy_pass http://embedding_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Authorization "Bearer ${API_KEY}";
        proxy_set_header Host $host;

        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 60s;

        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 2;
    }
}

# ── Reranker :8002 ───────────────────────────────────────────────────────────
server {
    listen 8002;
    client_max_body_size 64M;

    location / {
        proxy_pass http://reranker_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Authorization "Bearer ${API_KEY}";
        proxy_set_header Host $host;

        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 60s;

        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 2;
    }
}
