# Copy to .env and fill in values

# API key shared across all 3 services (llm, embedding, reranker)
API_KEY=sk-your-key-here

# HuggingFace token (required if models are gated)
HF_TOKEN=hf_xxx

# Local path to bind-mount as the HF model cache
HF_CACHE_DIR=/root/.cache/huggingface

# Set to 1 if GPUs are not NVLink-connected (common on PCIe A100 pods)
NCCL_P2P_DISABLE=1
