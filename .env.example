# Copy to .env and fill in values:  cp .env.example .env

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared API key across all 3 services. nginx injects this as a Bearer token, so
# clients hit the public ports (8000/8001/8002) without sending it themselves.
API_KEY=sk-secai2026

# HuggingFace token (required for gated models / faster downloads)
HF_TOKEN=hf_xxx

# ── Models ────────────────────────────────────────────────────────────────────
# LLM: NVFP4 build — native fast path on RTX 6000 Pro Blackwell (SM120).
# Served with --quantization modelopt + --kv-cache-dtype fp8, TP=1 (one card each).
LLM_MODEL=nvidia/Qwen3.6-35B-A3B-NVFP4
# Embedding: bge-m3 (MIT, multilingual, dim 1024). Served as a pooling model
# (--runner pooling). Swapped in from bge-large-en-v1.5 for multilingual recall.
EMBED_MODEL=BAAI/bge-m3
# Reranker: Qwen3-Reranker-0.6B (Apache-2.0). This is a CAUSAL-LM reranker, not a
# cross-encoder, so docker-compose serves it with --runner pooling + --hf-overrides
# (route to Qwen3ForSequenceClassification, classifier_from_token ["no","yes"],
# is_original_qwen3_reranker) + the qwen3_reranker.jinja chat template. Changing
# this id alone is NOT enough — those serve-args live in the &rerank-cmd block.
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B

# Max context for the LLM. NVFP4 weights (~20 GB) leave huge room for KV cache;
# raise toward 262144 if you need the model's full context window.
LLM_MAX_MODEL_LEN=65536

# vLLM image. Pin a tag for reproducibility (e.g. vllm/vllm-openai:v0.x.y).
VLLM_IMAGE=vllm/vllm-openai:latest

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# NOTE: No NVLink / P2P here — the RTX 6000 Pro is PCIe-only. Each GPU runs an
# independent replica (TP=1), so no cross-GPU NCCL traffic happens at all.
