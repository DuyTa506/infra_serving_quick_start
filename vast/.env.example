# vast.ai deployment — env vars for the instance template (and vast/on_start.sh).
# On vast.ai you set these in the template's "Environment Variables" box, NOT in a
# file. This file documents every knob on_start.sh reads, with defaults.
#
# ── Required ─────────────────────────────────────────────────────────────────
API_KEY=sk-secai2026           # shared bearer token; clients MUST send it (no nginx injection)
HF_TOKEN=hf_xxx                # HuggingFace token — faster pulls / gated models

# ── Models (defaults = a100/ variant; AWQ int4 LLM is the Ampere fast path) ──
LLM_MODEL=cpatonn/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
LLM_MAX_MODEL_LEN=32768        # int4 weights leave lots of room; can raise toward 262144

# ── Per-replica VRAM split (sums to ~0.91 → ~73/80 GB per A100) ──────────────
LLM_GPU_UTIL=0.80
EMBED_GPU_UTIL=0.05
RERANK_GPU_UTIL=0.06

# ── Public LB ports (also map these in the template's `-p` field) ────────────
LLM_PUB_PORT=8001
EMBED_PUB_PORT=8000
RERANK_PUB_PORT=8002

# ── Repo to clone for the reranker jinja template (override if you forked) ───
REPO_URL=https://github.com/DuyTa506/infra_serving_quick_start.git
REPO_REF=master

# ── Misc ─────────────────────────────────────────────────────────────────────
HF_HOME=/workspace/hf-cache    # persisted HF cache on instance disk
HEALTH_TIMEOUT=1200            # seconds to wait per replica /health (cold pull is slow)
# NUM_GPUS=2                    # auto-detected via nvidia-smi; set to override
